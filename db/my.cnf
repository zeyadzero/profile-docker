[mysqld]
# Disable symbolic link support - a common local-privilege-escalation vector
symbolic-links=0

# Never allow LOCAL INFILE loading - a classic path for reading arbitrary
# files off the server through a compromised client
local-infile=0

# Don't resolve hostnames for incoming connections - avoids DNS spoofing
# tricks affecting authentication and slows down connections less
skip-name-resolve

# Reasonable connection ceiling so a runaway client can't exhaust the DB
max_connections=100

# Log slow queries to help spot abuse / bad queries in review
slow_query_log=1
long_query_time=2
